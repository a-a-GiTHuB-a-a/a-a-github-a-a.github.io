{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    //"noImplicitAny": true,
    "module": "ES2022",
    "target": "ES2022",
    "allowJs": true,
    "paths": {
      "paper": ["./node_modules/paper/dist/paper-core.min.js"],
      "regex": ["./node_modules/regex/dist/esm/regex"],
      "ext/*": ["./node_modules/*"]
    },
    "types": ["paper", "regex"]
  },
  "moduleResolution": "nodenext"
}