{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "module": "ES2022",
    "target": "ES2020",
    "allowJs": true,
    "paths": {
      "paper": ["./node_modules/paper/dist/paper-core.min.js"],
      //"@types/paper": ["./node_modules/paper/dist/paper-core.d.ts"],
      "jquery": ["./node_modules/jquery/dist/jquery.min.js"],
      "@types/jquery": ["./node_modules/@types/jquery/index.d.ts"]
    },
    "types": ["paper", "jquery"]
  },
  "moduleResolution": "node"
}
